const fmtPU=v=>v==null?'–':Math.round(v).toLocaleString('pt-BR');

function kpis(co,y){
 const p=pl(co,y),b=bs(co,y);
 const o={};
 o.receita=p.receita;o.ebitda=p.ebitda;o.ll=p.lucro_liq;o.resfin=p.res_fin;o.ebit=p.ebit;
 o.mgEbitda=p.ebitda/p.receita; o.mgLiq=p.lucro_liq/p.receita; o.mgBruta=p.lucro_bruto/p.receita;
 o.dlEbitda=b.divida_liq/p.ebitda;
 o.dlImob=b.divida_liq/b.imobilizado;
 o.dlPl=b.divida_liq/b.pl;
 o.plAtivo=b.pl/b.ativo_total;
 o.resfinDl=p.res_fin/b.divida_liq;
 // ROE = Lucro Líquido / PL médio (média de 12/2024 e 12/2025)
 const plAvg=(bs(co,'2024').pl + bs(co,'2025').pl)/2;
 o.plMedio=plAvg;
 o.roe=p.lucro_liq/plAvg;
 o.roic=(p.ebit*(1-TAX))/(b.divida_liq+b.pl);
 o.ebitMg=p.ebit/p.receita;                       // margem EBIT
 o.montImob=(b.montadora!=null)?b.montadora/b.imobilizado:null; // fornecedores/montadora ÷ imobilizado
 o.spread=o.roic-Math.abs(o.resfinDl); // value spread vs funding cost
 o.divLiq=b.divida_liq;o.ativo=b.ativo_total;o.pleq=b.pl;o.imob=b.imobilizado;
 // segment metrics
 const g=gtf(co,y);o.gtfRec=g.receita;o.gtfEbitda=g.ebitda;o.gtfMg=g.ebitda/g.receita;
 o.gtfShare=g.receita/p.receita;
 return o;
}
function yoy(co,sel){ // growth of selected pl field 2024->2025
