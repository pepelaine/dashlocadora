    const best=d.dir===0?null:a.map((co,i)=>[co,rowVals[i]]).filter(x=>x[1]!=null).sort((p,q)=>d.dir<0?p[1]-q[1]:q[1]-p[1])[0];
    body+=`<tr><td class="metric">${d.label}</td>`;
    a.forEach((co,i)=>{
