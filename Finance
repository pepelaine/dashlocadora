  // quarterly trends
  const qlabels=QS;
  chart('dreTrendRev',{type:'line',data:{labels:qlabels,datasets:a.map(co=>({label:co,
      data:QS.map(q=>{const blkq=gtfMode?(DATA[co].gtf[q]):(DATA[co].pl[q]); return blkq?blkq.receita:null;}),
      borderColor:INK[co],backgroundColor:INK[co],tension:.3,borderWidth:2,pointRadius:2.5,spanGaps:true}))},
    options:lineOpts(v=>fmtMn(v))});
  chart('dreTrendMg',{type:'line',data:{labels:qlabels,datasets:a.map(co=>({label:co,
      data:QS.map(q=>{const b=gtfMode?DATA[co].gtf[q]:DATA[co].pl[q]; return b&&b.receita?b.ebitda/b.receita:null;}),
      borderColor:INK[co],backgroundColor:INK[co],tension:.3,borderWidth:2,pointRadius:2.5,spanGaps:true}))},
    options:lineOpts(v=>pct(v,1),true)});

  // bind dropdown
  const sel=document.getElementById('dreCo');
  if(sel)sel.onchange=e=>{state.dreCo=e.target.value;render();};
  dreInsights(a,y,gtfMode);
}

function lineOpts(fmt,isPct){return{maintainAspectRatio:false,interaction:{mode:'index',intersect:false},
  plugins:{legend:{display:true,position:'bottom',labels:{usePointStyle:true,pointStyle:'circle',padding:13,font:{family:"'Encode Sans'",weight:'600'}}},
    tooltip:{callbacks:{label:c=>c.dataset.label+': '+(c.parsed.y==null?'–':fmt(c.parsed.y))}}},
  scales:{x:{grid:{display:false},ticks:{font:{size:10.5,family:"'Encode Sans Condensed'",weight:'600'}}},y:{grid:{color:'#eef0f7'},ticks:{callback:v=>isPct?pct(v,1):fmtMn(v)}}}};}

function dreInsights(a,y,gtfMode){
  const el=document.getElementById('dreInsights');if(!el)return;
  const k=Object.fromEntries(a.map(c=>[c,kpis(c,y)]));
  const items=[];
  // revenue growth leader
  const gr=a.map(c=>[c,yoy(c,'receita')]).sort((p,q)=>q[1]-p[1]);
  items.push(['g',`<b>Volume/preço:</b> ${gr[0][0]} liderou o crescimento de receita (${pct(gr[0][1])} a/a), sinal de ganho de tarifa e/ou frota; ${gr[gr.length-1][0]} cresceu menos (${pct(gr[gr.length-1][1])}).`]);
  // margin / efficiency
  const mg=a.map(c=>[c,k[c].mgEbitda]).sort((p,q)=>q[1]-p[1]);
  items.push(['',`<b>Eficiência:</b> a margem EBITDA varia de ${pct(mg[mg.length-1][1])} (${mg[mg.length-1][0]}) a ${pct(mg[0][1])} (${mg[0][0]}). Modelos mais puros de GTF tendem a margem operacional maior, pois evitam o giro de baixo spread de RAC/Seminovos.`]);
  // financial result bite
  const fin=a.map(c=>[c,k[c].resfin/k[c].ebitda]).sort((p,q)=>p[1]-q[1]);
  items.push(['r',`<b>Custo de capital:</b> o resultado financeiro consome de ${pct(Math.abs(fin[fin.length-1][1]),0)} a ${pct(Math.abs(fin[0][1]),0)} do EBITDA. Em ${fin[0][0]} a mordida é a maior do grupo — principal motivo da compressão do lucro líquido em 2025.`]);
  // bottom line
  const ll=a.map(c=>[c,k[c].mgLiq]).sort((p,q)=>p[1]-q[1]);
  items.push(['o',`<b>Bottom line:</b> apesar de EBITDA crescente, ${ll[0][0]} fechou ${y} com margem líquida de ${pct(ll[0][1])} — a alavancagem transfere quase todo o ganho operacional para o serviço da dívida.`]);
  el.innerHTML=items.map(([t,h])=>`<li><span class="tag ${t}">${t==='g'?'+':t==='r'?'!':t==='o'?'△':'•'}</span><span>${h}</span></li>`).join('');
}

