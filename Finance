   <div class="grid g2"><div class="card span2" style="grid-column:span 2"><ul class="clean" id="dreInsights"></ul></div></div>
  `;

  // waterfall
  const steps=rowsFn(state.dreCo,y);
  let run=0; const floats=[],colors=[];
  const POS='#4EA72E', NEG='#FF0000';
  steps.forEach(s=>{
    if(s.t==='tot'||s.t==='sub'){ floats.push([0,s.v]); colors.push(s.v>=0?POS:NEG); run=s.v; }
    else { const from=run, to=run+s.v; floats.push([from,to]); colors.push(s.v>=0?POS:NEG); run=to; }
  });
  // bridge: conectores entre os degraus
  const bridgeConnectors={id:'bridge',afterDatasetsDraw(ch){try{
    const m=ch.getDatasetMeta(0),ys=ch.scales.y,c=ch.ctx;if(!m||!ys)return;
    c.save();c.strokeStyle='#8a93ad';c.lineWidth=1;c.setLineDash([3,3]);
    for(let i=0;i<m.data.length-1;i++){
      const e=m.data[i],n=m.data[i+1];const yv=ys.getPixelForValue(floats[i][1]);
      c.beginPath();c.moveTo(e.x+e.width/2,yv);c.lineTo(n.x-n.width/2,yv);c.stroke();
    }
    c.restore();
  }catch(e){}}};
  chart('dreFall',{type:'bar',data:{labels:steps.map(s=>s.l),datasets:[{data:floats,backgroundColor:colors,borderColor:colors,borderWidth:1,borderRadius:3,maxBarThickness:38}]},
    plugins:[bridgeConnectors],
    options:{maintainAspectRatio:false,indexAxis:'x',plugins:{legend:{display:false},barLabels:{fmt:v=>Math.round(v).toLocaleString('pt-BR')},tooltip:{callbacks:{label:c=>{const v=c.raw;return 'R$ '+fmtMn(v[1]-v[0])+' (acum. '+fmtMn(v[1])+')';}}}},
