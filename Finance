const barLabelsPlugin={
 id:'barLabels',
 afterDatasetsDraw(chart){
  try{
   const cop=chart.config&&chart.config.options&&chart.config.options.plugins;
   const o=cop&&cop.barLabels;
   if(o&&o.display===false)return;
   const horiz=chart.options.indexAxis==='y';
   const vAxis=horiz?'x':'y';
   const sc=chart.options.scales&&chart.options.scales[vAxis];
   const cb=sc&&sc.ticks&&sc.ticks.callback;
   const fmt=(o&&typeof o.fmt==='function')?o.fmt:((typeof cb==='function')?(v=>cb(v,0,[])):(v=>Math.round(v).toLocaleString('pt-BR')));
   const customColor=o&&o.color;
   const stacked=!!(sc&&sc.stacked);
   const ctx=chart.ctx;ctx.save();ctx.font="700 10px 'Encode Sans Condensed','Encode Sans',sans-serif";
   chart.data.datasets.forEach((ds,di)=>{
     const meta=chart.getDatasetMeta(di);
     if(meta.type!=='bar'||meta.hidden)return;
     meta.data.forEach((el,i)=>{
       const raw=ds.data[i];if(raw==null)return;
       const val=Array.isArray(raw)?(raw[1]-raw[0]):raw;
       if(val==null||(stacked&&Math.abs(val)<1e-9))return;
       const txt=fmt(val);
       if(stacked){
         ctx.fillStyle=customColor||'#fff';ctx.textAlign='center';ctx.textBaseline='middle';
         if(horiz)ctx.fillText(txt,(el.x+el.base)/2,el.y);else ctx.fillText(txt,el.x,(el.y+el.base)/2);
       }else{
         ctx.fillStyle=customColor||'#1a1f36';
         if(horiz){ctx.textAlign='left';ctx.textBaseline='middle';ctx.fillText(txt,el.x+6,el.y);}
         else{ctx.textAlign='center';const neg=el.y>el.base;ctx.textBaseline=neg?'top':'bottom';ctx.fillText(txt,el.x,neg?el.y+4:el.y-4);}
       }
     });
   });
   ctx.restore();
  }catch(e){ /* nunca deixar o rótulo quebrar o desenho dos gráficos */ }
 }
};
