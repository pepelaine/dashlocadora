      </div>
    </div>
  </div>`;
}

/* ---------- chips ---------- */
function buildChips(){
  const el=document.getElementById('chips');if(!el)return;
  el.innerHTML=ORDER.map(co=>`<div class="chip ${state.on.has(co)?'on':'off'}" data-co="${co}" style="${state.on.has(co)?'color:'+INK[co]:''}"><span class="dot" style="background:${COL[co]};border:1px solid ${BORD[co]}"></span>${co}</div>`).join('');
  el.querySelectorAll('.chip').forEach(c=>c.onclick=()=>{
    const co=c.dataset.co;
    if(state.on.has(co)){ if(state.on.size>1) state.on.delete(co); }
    else state.on.add(co);
    render();
  });
}

