function kpiInsights(a,y,K){
  const el=document.getElementById('kpiInsights');if(!el)return;
  const items=[];
  const lev=a.slice().sort((x,z)=>K[x].dlEbitda-K[z].dlEbitda);
  items.push(['g',`<b>${lev[0]}</b> combina a menor alavancagem (${mult(K[lev[0]].dlEbitda)}) com a maior capitalização (PL/Ativo ${pct(K[lev[0]].plAtivo)}) — o balanço mais defensivo do grupo.`]);
  const bestRoic=a.map(c=>[c,K[c].roic]).sort((p,q)=>q[1]-p[1])[0];
  items.push(['',`<b>${bestRoic[0]}</b> tem o maior ROIC (${pct(bestRoic[1])}), mas convém checar à custa de qual alavancagem (DL/PL de ${mult(K[bestRoic[0]].dlPl)}).`]);
  const neg=a.filter(c=>(K[c].roic-Math.abs(K[c].resfinDl))<0);
  if(neg.length)items.push(['r',`<b>Spread negativo</b> em ${neg.join(', ')}: o ROIC não cobre o custo da dívida (~${pct(Math.abs(K[neg[0]].resfinDl),0)}). Cada real adicional de dívida destrói valor até a Selic ceder ou os contratos serem reprecificados.`]);
  else items.push(['g',`Todos os players exibem spread ROIC – custo da dívida positivo em ${y}.`]);
  items.push(['o',`<b>Alavancas de valor:</b> (1) desalavancar via geração de caixa e disciplina de capex de frota; (2) reprecificar contratos de GTF repassando juros; (3) alongar e baratear o funding. Quem girar essas três alavancas primeiro reabre o spread positivo.`]);
  el.innerHTML=items.map(([t,h])=>`<li><span class="tag ${t}">${t==='g'?'+':t==='r'?'!':t==='o'?'△':'•'}</span><span>${h}</span></li>`).join('');
}

/* ---------- VOLUME DE FROTA ---------- */
function vol(co,scope,y){const v=VOL[co];return v&&v[scope]?v[scope][y]:null;}
function volGrowth(co,scope){const a=vol(co,scope,'2024'),b=vol(co,scope,'2025');return (a&&b!=null)?(b-a)/a:null;}

