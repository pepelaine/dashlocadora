    options:{maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>(c.parsed.y>=0?'+':'')+pct(c.parsed.y)}}},
      scales:{x:{grid:{display:false},ticks:{font:{family:"'Encode Sans Condensed'",weight:'700',size:12}}},y:{grid:{color:'#eef0f7'},ticks:{callback:v=>pct(v,1)}}}}});

  const scope=segMode?'gtf':'total';
  chart('volProd',{type:'bar',data:{labels:a,datasets:[
    {label:'Receita / veículo',data:a.map(co=>perUnit(blk(co,y).receita,vol(co,scope,y))),backgroundColor:a.map(co=>COL[co]),borderColor:a.map(co=>BORD[co]),borderWidth:1,borderRadius:5,maxBarThickness:40},
    {label:'EBITDA / veículo',data:a.map(co=>perUnit(blk(co,y).ebitda,vol(co,scope,y))),backgroundColor:a.map(co=>COL[co]+'55'),borderColor:a.map(co=>BORD[co]),borderWidth:1,borderRadius:5,maxBarThickness:40}
  ]},options:{maintainAspectRatio:false,plugins:{legend:{display:true,position:'bottom',labels:{usePointStyle:true,pointStyle:'rectRounded',padding:14,font:{family:"'Encode Sans'",weight:'600'}}},tooltip:{callbacks:{label:c=>c.dataset.label+': R$ '+fmtPU(c.parsed.y)}}},
    scales:{x:{grid:{display:false},ticks:{font:{family:"'Encode Sans Condensed'",weight:'700',size:12}}},y:{grid:{color:'#eef0f7'},ticks:{callback:v=>'R$ '+fmtPU(v)}}}}});

  volInsights(a,y);
}

function volInsights(a,y){
  const el=document.getElementById('volInsights');if(!el)return;
  const items=[];
  const bySize=a.map(c=>[c,vol(c,'total',y)]).filter(x=>x[1]!=null).sort((p,q)=>q[1]-p[1]);
  if(bySize.length>=2)items.push(['',`<b>Escala:</b> ${bySize[0][0]} opera a maior frota (${bySize[0][1].toLocaleString('pt-BR')} veículos) — cerca de ${ (bySize[0][1]/bySize[bySize.length-1][1]).toLocaleString('pt-BR',{maximumFractionDigits:0}) }× a menor (${bySize[bySize.length-1][0]}).`]);
  const grow=a.map(c=>[c,volGrowth(c,'total')]).filter(x=>x[1]!=null).sort((p,q)=>q[1]-p[1]);
  if(grow.length)items.push(['g',`<b>Expansão:</b> ${grow[0][0]} cresceu a frota ${pct(grow[0][1])} a/a, o maior avanço do grupo; ${grow[grow.length-1][0]} reduziu (${pct(grow[grow.length-1][1])}), sinal de gestão mais defensiva de capex.`]);
  // productivity consolidado
  const prod=a.map(c=>[c,perUnit(pl(c,y).receita,vol(c,'total',y))]).filter(x=>x[1]!=null).sort((p,q)=>q[1]-p[1]);
  if(prod.length)items.push(['',`<b>Produtividade:</b> a receita por veículo varia de R$ ${fmtPU(prod[prod.length-1][1])} (${prod[prod.length-1][0]}) a R$ ${fmtPU(prod[0][1])} (${prod[0][0]}) — diferença puxada pelo mix RAC × GTF.`]);
  const stla=a.includes('Stellantis');
  if(stla)items.push(['o',`<b>Stellantis:</b> frota praticamente dobrou (10,2 mil → 21,1 mil). Por ser fim de período em rampa acelerada, a receita por veículo aparece subestimada — a base média do ano foi bem menor que a de dezembro.`]);
  el.innerHTML=items.map(([t,h])=>`<li><span class="tag ${t}">${t==='g'?'+':t==='r'?'!':t==='o'?'△':'•'}</span><span>${h}</span></li>`).join('');
}

/* ---------- KPIs GERENCIAIS ---------- */
// kind: 'reais' (R$/veículo) ou 'pct'. dir: +1 maior melhor / -1 menor melhor
const MDEF=[
  {key:'recVeic', kind:'reais', dir:1, label:'Receita líquida / veículo',
   formula:'Receita líquida ÷ frota total (fim do período)',
   interp:'Faturamento médio anual por carro. Operações com mais RAC (diária) faturam mais por veículo; GTF puro tem ticket menor, porém contratado e previsível.',
   fn:(co,y)=>perUnit(pl(co,y).receita, fleetTotal(co,y))},
  {key:'custosRec', kind:'pct', dir:-1, label:'Custos operacionais / Receita líquida',
   formula:'Custos operacionais ÷ Receita líquida',
   interp:'Peso dos custos diretos (operação e depreciação alocada em custos) sobre a receita. Quanto menor, maior a margem bruta.',
   fn:(co,y)=>Math.abs(pl(co,y).custos)/pl(co,y).receita},
  {key:'gnaRec', kind:'pct', dir:-1, label:'G&A / Receita líquida',
   formula:'Despesas operacionais (G&A) ÷ Receita líquida',
   interp:'Eficiência administrativa e comercial. Empresas mais enxutas diluem melhor a estrutura sobre a receita. As definições de despesa operacional variam por empresa — leia o ranking, não as diferenças de poucos p.p.',
   fn:(co,y)=>Math.abs(pl(co,y).gna)/pl(co,y).receita},
  {key:'ebitdaRec', kind:'pct', dir:1, label:'EBITDA / Receita líquida',
   formula:'EBITDA ÷ Receita líquida',
   interp:'Margem de geração de caixa operacional. É a mais alta do P&L no setor, pois adiciona de volta a forte depreciação da frota.',
   fn:(co,y)=>pl(co,y).ebitda/pl(co,y).receita},
  {key:'resfinRec', kind:'pct', dir:1, label:'Resultado financeiro / Receita líquida',
   formula:'Resultado financeiro ÷ Receita líquida',
   interp:'Quanto da receita é consumido pelo serviço da dívida. Em 2025, com Selic elevada, é o principal vetor de compressão do lucro líquido — mais negativo, pior.',
   fn:(co,y)=>pl(co,y).res_fin/pl(co,y).receita},
  {key:'ebitRec', kind:'pct', dir:1, label:'EBIT / Receita líquida',
   formula:'EBIT ÷ Receita líquida',
   interp:'Margem operacional após a depreciação da frota — mede a rentabilidade real da operação antes de juros e impostos.',
   fn:(co,y)=>pl(co,y).ebit/pl(co,y).receita}
];
function mval(d,co,y){try{return d.fn(co,y);}catch(e){return null;}}
function mfmt(d,v){return d.kind==='reais'?(v==null?'–':'R$ '+fmtPU(v)):pct(v,1);}

function renderMgmt(a){
  const y=state.year;
  // matrix
  let head=`<tr><th>Indicador gerencial · ${y}</th>${a.map(co=>`<th class="sep">${logoBadge(co,12)}</th>`).join('')}<th>Melhor</th></tr>`;
  let body='';
  MDEF.forEach(d=>{
    const rowVals=a.map(co=>mval(d,co,y));
    const best=a.map((co,i)=>[co,rowVals[i]]).filter(x=>x[1]!=null).sort((p,q)=>d.dir<0?p[1]-q[1]:q[1]-p[1])[0];
    body+=`<tr><td class="metric">${d.label}</td>`;
    a.forEach((co,i)=>{
      const v=rowVals[i];const [bg,fg]=heatColor(v,rowVals,d.dir);
      body+=`<td class="sep"><span class="heat num" style="background:${bg};color:${fg}">${mfmt(d,v)}</span></td>`;
    });
    body+=`<td style="font-weight:700;color:${best?INK[best[0]]:'inherit'}">${best?best[0]:'–'}</td></tr>`;
  });

  let cards='';
  MDEF.forEach(d=>{
    cards+=`<div class="card"><h3><span class="barK"></span>${d.label}</h3>
      <div class="sub"><b>Fórmula:</b> ${d.formula}</div>
      <div class="chwrap sm"><canvas id="m_${d.key}"></canvas></div>
      <p class="note" style="margin-top:10px">${d.interp}</p></div>`;
  });

  C().innerHTML=`
   <div class="card"><h3><span class="barK"></span>Matriz gerencial — ${a.length} empresas</h3>
     <div class="sub">Decomposição da receita líquida · heatmap: verde = melhor posição relativa, vermelho = pior · ${y}</div>
     <div class="scroll"><table class="tbl">${head}${body}</table></div>
     <div class="callout" style="margin-top:12px">Ratios calculados no <b>consolidado</b> de cada empresa. As linhas de custo e G&amp;A seguem a classificação reportada por cada companhia, que pode diferir — a leitura mais robusta é a ordenação relativa, não diferenças de poucos pontos percentuais.</div>
   </div>

   <div class="sectionhead"><span class="n">GER</span><h2>Cada ratio, lado a lado</h2><p>Decomposição da margem da receita ao EBIT</p></div>
   <div class="grid g2">${cards}</div>

   <div class="sectionhead"><span class="n">★</span><h2>Leitura gerencial</h2><p>Onde cada player ganha ou perde margem</p></div>
   <div class="grid g2"><div class="card span2" style="grid-column:span 2"><ul class="clean" id="mgmtInsights"></ul></div></div>`;

  MDEF.forEach(d=>{
    const vals=a.map(co=>mval(d,co,y));
    chart('m_'+d.key,{type:'bar',data:{labels:a,datasets:[{data:vals,backgroundColor:a.map(co=>COL[co]),borderColor:a.map(co=>BORD[co]),borderWidth:1,borderRadius:5,maxBarThickness:42}]},
      options:{maintainAspectRatio:false,plugins:{legend:{display:false},barLabels:{fmt:v=>d.kind==='reais'?fmtPU(v):pct(v,1)},tooltip:{callbacks:{label:c=>mfmt(d,c.parsed.y)}}},
        scales:{x:{grid:{display:false},ticks:{font:{family:"'Encode Sans Condensed'",weight:'700',size:11}}},
          y:{grid:{display:false},ticks:{callback:v=>d.kind==='reais'?fmtPU(v):pct(v,1)}}}}});
  });

  mgmtInsights(a,y);
}

function mgmtInsights(a,y){
  const el=document.getElementById('mgmtInsights');if(!el)return;
  const items=[];
  const rv=a.map(c=>[c,mval(MDEF[0],c,y)]).filter(x=>x[1]!=null).sort((p,q)=>q[1]-p[1]);
  if(rv.length)items.push(['',`<b>Receita por veículo:</b> ${rv[0][0]} fatura R$ ${fmtPU(rv[0][1])} por carro/ano, ante R$ ${fmtPU(rv[rv.length-1][1])} de ${rv[rv.length-1][0]} — diferença puxada pelo mix RAC × GTF.`]);
  const eb=a.map(c=>[c,pl(c,y).ebitda/pl(c,y).receita]).sort((p,q)=>q[1]-p[1]);
  items.push(['g',`<b>Margem EBITDA:</b> ${eb[0][0]} lidera (${pct(eb[0][1])}); ${eb[eb.length-1][0]} fecha o grupo (${pct(eb[eb.length-1][1])}).`]);
  const fin=a.map(c=>[c,pl(c,y).res_fin/pl(c,y).receita]).sort((p,q)=>p[1]-q[1]);
  items.push(['r',`<b>Peso financeiro:</b> em ${fin[0][0]} o resultado financeiro consome ${pct(Math.abs(fin[0][1]))} da receita — a maior mordida; é o elo entre uma boa margem operacional e um lucro líquido espremido.`]);
  const conv=a.map(c=>[c,pl(c,y).ebit/pl(c,y).receita]).sort((p,q)=>q[1]-p[1]);
  items.push(['o',`<b>Margem EBIT:</b> após a depreciação da frota, ${conv[0][0]} mantém a maior margem operacional (${pct(conv[0][1])}). A depreciação é o custo que mais separa EBITDA de EBIT no setor.`]);
  el.innerHTML=items.map(([t,h])=>`<li><span class="tag ${t}">${t==='g'?'+':t==='r'?'!':t==='o'?'△':'•'}</span><span>${h}</span></li>`).join('');
}

