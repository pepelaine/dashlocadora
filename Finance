function dreRows(co,y){
  const p=pl(co,y);
  const despOp=p.ebitda-p.lucro_bruto;          // SG&A líquido de reclassificações até o EBITDA
  const aoi=p.ebit+p.res_fin;                    // Resultado Ajustado (AOI) = resultado antes do IR
  const ir=p.lucro_liq-aoi;                      // IR/CSLL & participações
  return [
    {k:'receita',   l:'Receita líquida',          v:p.receita,     t:'tot'},
    {k:'custos',    l:'Custos',                    v:p.custos,      t:'neg'},
    {k:'lucro_bruto',l:'Lucro bruto',              v:p.lucro_bruto, t:'sub'},
    {k:'despop',    l:'Desp. oper. / ajustes',     v:despOp,        t:'delta'},
    {k:'ebitda',    l:'EBITDA',                    v:p.ebitda,      t:'sub'},
    {k:'deprec',    l:'Depreciação & amortização', v:p.deprec,      t:'neg'},
    {k:'ebit',      l:'EBIT',                      v:p.ebit,        t:'sub'},
    {k:'res_fin',   l:'Resultado financeiro',      v:p.res_fin,     t:'neg'},
    {k:'aoi',       l:'Resultado Ajustado (AOI)',  v:aoi,           t:'sub'},
    {k:'ir',        l:'IR/CSLL & outros',          v:ir,            t:'delta'},
    {k:'lucro_liq', l:'Lucro líquido',             v:p.lucro_liq,   t:'tot'}
  ];
}
// recorte GTF: segmento real até o EBIT; abaixo, alocação proporcional pela frota de GTF
function dreRowsGtf(co,y){
  const g=gtf(co,y), p=pl(co,y);
  const tf=fleetTotal(co,y), gf=fleetGtf(co,y);
  const ratio=(tf&&gf!=null)?gf/tf:1;            // participação da frota de GTF
  const resFinProp=p.res_fin*ratio;
  const aoiProp=g.ebit+resFinProp;
  const irConsol=p.lucro_liq-p.ebit-p.res_fin;
  const irProp=irConsol*ratio;
  const netProp=aoiProp+irProp;
  return [
    {k:'receita',l:'Receita líquida (GTF)',     v:g.receita,                t:'tot'},
    {k:'cd',     l:'Custos & despesas',          v:g.ebitda-g.receita,       t:'neg'},
    {k:'ebitda', l:'EBITDA (GTF)',               v:g.ebitda,                 t:'sub'},
    {k:'deprec', l:'Depreciação (frota)',        v:g.ebit-g.ebitda,          t:'neg'},
    {k:'ebit',   l:'EBIT (GTF)',                 v:g.ebit,                   t:'sub'},
    {k:'res_fin',l:'Resultado financeiro ◳',     v:resFinProp,               t:'neg',  prop:true},
    {k:'aoi',    l:'Resultado Ajustado (AOI) ◳', v:aoiProp,                  t:'sub',  prop:true},
    {k:'ir',     l:'IR/CSLL & outros ◳',         v:irProp,                   t:'delta',prop:true},
    {k:'lucro_liq',l:'Lucro líquido (GTF) ◳',    v:netProp,                  t:'tot',  prop:true}
  ];
}

