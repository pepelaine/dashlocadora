<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Benchmarking Competitivo · Locadoras de Frota</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Encode+Sans:wght@300;400;500;600;700;800&family=Encode+Sans+Condensed:wght@400;500;600;700&family=Encode+Sans+Semi+Condensed:wght@500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root{
  --navy:#243782; --navy-2:#33489c; --navy-3:#5468b8; --navy-soft:#eaeefb;
  --ink:#1a1f36; --muted:#6b7390; --line:#e4e7f1; --bg:#f3f4f9; --card:#ffffff;
  --c-localiza:#046C2F; --c-movida:#FF4F01; --c-unidas:#007ED2; --c-lm:#D9D9D9;
  --good:#1f8a5b; --bad:#c0392b; --gold:#c9a227;
}
*{box-sizing:border-box;margin:0;padding:0}
html{-webkit-text-size-adjust:100%}
body{font-family:'Encode Sans',system-ui,sans-serif;background:var(--bg);color:var(--ink);font-size:14px;line-height:1.45;-webkit-font-smoothing:antialiased}
.num{font-family:'Encode Sans Condensed','Encode Sans',sans-serif;font-variant-numeric:tabular-nums}

/* ---------- shell ---------- */
.shell{display:grid;grid-template-columns:236px 1fr;min-height:100vh}
.side{background:var(--navy);color:#fff;display:flex;flex-direction:column;position:sticky;top:0;height:100vh}
.brand{padding:22px 22px 18px;border-bottom:1px solid rgba(255,255,255,.12)}
.brand .mark{font-family:'Encode Sans Semi Condensed';font-weight:700;letter-spacing:.14em;font-size:11px;color:var(--gold);text-transform:uppercase}
.brand h1{font-size:17px;font-weight:700;margin-top:6px;line-height:1.2}
.brand h1.titleY{color:#FFCB05;letter-spacing:.06em;font-weight:800;font-size:19px}
.sidemeta{padding:12px 22px 18px}
.sidemeta .lbl{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.42);font-weight:600;padding:0 0 5px}
.sidemeta .cos{font-size:11.5px;color:rgba(255,255,255,.72);font-weight:600;margin-bottom:12px}
.brand p{font-size:11.5px;color:rgba(255,255,255,.6);margin-top:5px}
.nav{padding:14px 12px;flex:1}
.nav .lbl{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.42);padding:8px 12px 6px;font-weight:600}
.nav button{display:flex;align-items:center;gap:11px;width:100%;background:none;border:0;color:rgba(255,255,255,.82);font-family:inherit;font-size:13.5px;font-weight:500;padding:10px 12px;border-radius:9px;cursor:pointer;text-align:left;transition:.15s}
.nav button:hover{background:rgba(255,255,255,.08);color:#fff}
.nav button.active{background:#fff;color:var(--navy);font-weight:600}
.nav button .ic{width:17px;height:17px;flex:none;opacity:.9}
.nav button.active .ic{opacity:1}
.side .foot{padding:13px 0 0;font-size:10.5px;color:rgba(255,255,255,.6);border-top:1px solid rgba(255,255,255,.14);line-height:1.7}
.side .foot b{color:#fff;font-weight:700}

.main{display:flex;flex-direction:column;min-width:0}
/* ---------- topbar / filters ---------- */
.topbar{background:var(--card);border-bottom:1px solid var(--line);padding:14px 28px;position:sticky;top:0;z-index:20}
.topbar .row{display:flex;align-items:center;gap:22px;flex-wrap:wrap}
.pagetitle{margin-right:auto}
.pagetitle h2{font-size:18px;font-weight:700}
.pagetitle span{font-size:12px;color:var(--muted)}
.fgroup{display:flex;align-items:center;gap:8px}
.fgroup .flbl{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);font-weight:600}
.seg{display:flex;background:var(--bg);border:1px solid var(--line);border-radius:9px;padding:3px}
.seg button{border:0;background:none;font-family:inherit;font-size:12.5px;font-weight:600;color:var(--muted);padding:6px 13px;border-radius:6px;cursor:pointer;transition:.15s}
.seg button.on{background:var(--navy);color:#fff}
.chips{display:flex;gap:7px;flex-wrap:wrap}
.chip{display:flex;align-items:center;gap:7px;border:1.5px solid var(--line);background:var(--card);border-radius:20px;padding:5px 12px 5px 9px;font-size:12.5px;font-weight:600;cursor:pointer;color:var(--muted);transition:.15s;user-select:none}
.chip .dot{width:9px;height:9px;border-radius:50%}
.chip.on{color:var(--ink);border-color:currentColor}
.chip.off{opacity:.45}

/* ---------- canvas ---------- */
.canvas{padding:24px 28px 56px;max-width:1320px}
.page{display:none;animation:fade .35s ease}
.page.show{display:block}
@keyframes fade{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.grid{display:grid;gap:16px}
.g4{grid-template-columns:repeat(4,1fr)}
.g3{grid-template-columns:repeat(3,1fr)}
.g2{grid-template-columns:repeat(2,1fr)}
.span2{grid-column:span 2}
.card{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:18px 20px}
.card h3{font-size:13.5px;font-weight:700;display:flex;align-items:center;gap:8px}
.card .sub{font-size:11.5px;color:var(--muted);margin-top:2px;margin-bottom:8px}
.card .barK{width:4px;height:15px;border-radius:3px;background:var(--gold);display:inline-block}
.sectionhead{display:flex;align-items:baseline;gap:12px;margin:30px 2px 14px}
.sectionhead .n{font-family:'Encode Sans Semi Condensed';font-weight:700;font-size:12px;color:var(--gold);letter-spacing:.1em}
.sectionhead h2{font-size:16px;font-weight:700}
.sectionhead p{font-size:12px;color:var(--muted);margin-left:auto;max-width:520px;text-align:right}

/* KPI tiles */
.kpi{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:16px 17px;position:relative;overflow:hidden}
.kpi .co{font-size:11px;font-weight:700;letter-spacing:.04em;display:flex;align-items:center;gap:7px;color:var(--muted)}
.kpi .co .dot{width:9px;height:9px;border-radius:50%}
.kpi .big{font-family:'Encode Sans Condensed';font-weight:700;font-size:30px;line-height:1.05;margin-top:9px;letter-spacing:-.01em}
.kpi .lbl{font-size:11px;color:var(--muted);margin-top:1px}
.kpi .delta{font-size:11.5px;font-weight:600;margin-top:9px;display:inline-flex;align-items:center;gap:4px}
.up{color:var(--good)} .down{color:var(--bad)}
.kpi .edge{position:absolute;left:0;top:0;bottom:0;width:4px}

/* tables */
.tbl{width:100%;border-collapse:collapse;font-size:12.5px}
.tbl th,.tbl td{padding:9px 10px;text-align:center;border-bottom:1px solid var(--line);white-space:nowrap}
.tbl th{font-size:10.5px;letter-spacing:.06em;text-transform:uppercase;color:var(--muted);font-weight:700;background:var(--bg)}
.tbl td.metric{font-weight:600}
.tbl tr.head td{background:var(--navy-soft);font-weight:700;color:var(--navy)}
.tbl tr.tot td{font-weight:700;border-top:2px solid var(--navy);border-bottom:2px solid var(--navy)}
.tbl tr.prop td{background:#fff3e6 !important}
.tbl tr.prop.tot td{border-top-color:#f0a35a;border-bottom-color:#f0a35a}
.tbl tr.prop td.metric{color:#b5651d}
.propchip{display:inline-block;width:12px;height:12px;border-radius:3px;background:#fff3e6;border:1px solid #f0a35a;vertical-align:-2px;margin-right:6px}
.tbl th.sep,.tbl td.sep{border-left:2px solid #c8cee0}
.tbl td .pct{font-size:10.5px;color:var(--muted);font-weight:500;margin-left:4px}
.tbl .num{font-family:'Encode Sans Condensed';font-variant-numeric:tabular-nums}
.heat{border-radius:5px;padding:2px 7px;font-weight:700}
.scroll{overflow-x:auto}

.chwrap{position:relative;height:300px}
.chwrap.tall{height:360px}
.chwrap.sm{height:240px}
.legend{display:flex;gap:14px;flex-wrap:wrap;font-size:11.5px;color:var(--muted);margin-top:10px}
.legend span{display:inline-flex;align-items:center;gap:6px}
.legend i{width:11px;height:11px;border-radius:3px;display:inline-block}

.note{font-size:11.5px;color:var(--muted);line-height:1.55}
.callout{background:var(--navy-soft);border-left:3px solid var(--navy);border-radius:0 10px 10px 0;padding:12px 15px;font-size:12.5px;line-height:1.55}
.callout b{color:var(--navy)}
ul.clean{list-style:none;display:flex;flex-direction:column;gap:9px}
ul.clean li{display:flex;gap:10px;font-size:12.8px;line-height:1.5;align-items:flex-start}
ul.clean li .tag{flex:none;font-family:'Encode Sans Condensed';font-weight:700;font-size:11px;padding:1px 7px;border-radius:5px;background:var(--navy-soft);color:var(--navy);margin-top:1px}
ul.clean li .tag.r{background:#fbeae7;color:var(--bad)}
ul.clean li .tag.g{background:#e7f3ec;color:var(--good)}
ul.clean li .tag.o{background:#fbf2da;color:#9a7b13}
.q{font-size:12.8px;line-height:1.5;padding:11px 14px;border:1px solid var(--line);border-radius:10px;background:var(--bg)}
.q b{color:var(--navy)}
.metawrap{display:flex;flex-direction:column;gap:10px}
.metawrap h4{font-size:13px;font-weight:700;color:var(--navy);margin-top:4px}
.metawrap p,.metawrap li{font-size:12.6px;line-height:1.6;color:#2c324d}
.metawrap ul{padding-left:18px;display:flex;flex-direction:column;gap:5px}
.dredrop{display:flex;align-items:center;gap:9px}
select{font-family:inherit;font-size:12.5px;font-weight:600;border:1.5px solid var(--line);border-radius:9px;padding:7px 11px;background:var(--card);color:var(--ink);cursor:pointer}
.pill{font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:3px 9px;border-radius:20px;background:var(--navy-soft);color:var(--navy)}
.wm{font-family:'Encode Sans Semi Condensed','Encode Sans',sans-serif;font-weight:800;letter-spacing:.01em;color:var(--wc);display:inline-flex;align-items:center;line-height:1}
.logo{height:20px;width:auto;max-width:150px;object-fit:contain;vertical-align:middle;display:inline-block}
.dashfoot{display:flex;flex-wrap:wrap;align-items:center;gap:8px;padding:16px 26px 28px;color:var(--muted);font-size:11.5px;border-top:1px solid var(--line);margin-top:6px}
.dashfoot b{color:var(--ink);font-weight:700}
.dashfoot .sep{opacity:.5}
@media(max-width:1100px){.g4{grid-template-columns:repeat(2,1fr)}.g3{grid-template-columns:1fr 1fr}}
@media(max-width:820px){.shell{grid-template-columns:1fr}.side{position:static;height:auto;flex-direction:row;flex-wrap:wrap}.nav{display:flex;flex-wrap:wrap}.g4,.g3,.g2{grid-template-columns:1fr}.span2{grid-column:auto}.sectionhead p{display:none}}
</style>
</head>
