   interp:'Parcela da frota financiada via crédito de fornecedores (montadoras). Um indicador de capital de giro: quanto maior, mais a aquisição de veículos é sustentada por prazo com a montadora, aliviando dívida financeira. Para as listadas usa-se o saldo de fornecedores (a montadora é o principal componente); para a Stellantis, a linha reportada de Custo com a Montadora.'}
];

function heatColor(v,row,dir){
  const vals=row.filter(x=>x!=null&&isFinite(x));
  if(!vals.length||v==null)return ['transparent','inherit'];
  if(dir===0)return ['rgba(36,55,130,0.10)','var(--navy)']; // indicador neutro (sem melhor/pior)
  const min=Math.min(...vals),max=Math.max(...vals);
  if(max===min)return ['var(--navy-soft)','var(--navy)'];
  let t=(v-min)/(max-min);            // 0..1
  if(dir<0)t=1-t;                     // invert when lower=better
  // t=1 good (green), t=0 bad (red)
  const g=[31,138,91], r=[192,57,43], mid=[214,180,40];
  let col; if(t>=.5){const f=(t-.5)*2;col=mid.map((m,i)=>Math.round(m+(g[i]-m)*f));}
  else{const f=t*2;col=r.map((rr,i)=>Math.round(rr+(mid[i]-rr)*f));}
  const bg=`rgba(${col[0]},${col[1]},${col[2]},0.16)`;
  const fg=`rgb(${Math.round(col[0]*.7)},${Math.round(col[1]*.7)},${Math.round(col[2]*.7)})`;
  return [bg,fg];
}

function kpiFmt(kind,v){return kind==='mult'?mult(v,1):pct(v,1);}

function renderKPI(a){
